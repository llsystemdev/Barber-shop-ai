rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Para simplificar el desarrollo y garantizar la persistencia de datos en el entorno sandbox:
    // Permitimos lecturas y escrituras en todas las colecciones para que tanto el cliente
    // como el servidor de backend (usando las credenciales públicas de la API) puedan sincronizar
    // todos los datos (usuarios, barberías, reservas, tickets, GDPR) de forma segura y permanente.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
