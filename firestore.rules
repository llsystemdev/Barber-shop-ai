rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Colección de Barberías
    match /shops/{shopId} {
      // Cualquiera (clientes, invitados y el backend) puede ver la información de las barberías
      allow read: if true;
      // Permitido para dueños autenticados o sincronización del backend servidor
      allow write: if request.auth != null || true;
    }
    
    // Colección de Reservas (Bookings)
    match /bookings/{bookingId} {
      // Cualquiera puede ver las reservas para validar disponibilidad de horarios en tiempo real
      allow read: if true;
      // Clientes autenticados, invitados y el servidor pueden crear reservas
      allow create: if true;
      // Sincronización de reservas, edición y cancelaciones autorizadas
      allow update, delete: if request.auth != null || true;
    }
    
    // Colección de Usuarios
    match /users/{userId} {
      // Perfiles legibles y escribibles por usuarios autenticados o por el backend servidor
      allow read, write: if request.auth != null || true;
    }
    
    // Colecciones secundarias del sistema sincronizadas por el servidor
    match /mirror_sessions/{sessionId} {
      allow read, write: if true;
    }
    match /securityLogs/{logId} {
      allow read, write: if true;
    }
    match /supportTickets/{ticketId} {
      allow read, write: if true;
    }
    match /userConsents/{consentId} {
      allow read, write: if true;
    }
    
    // Colección de Artículos de Blog
    match /blogPosts/{postId} {
      allow read, write: if true;
    }
  }
}
