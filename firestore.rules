rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SECURITY HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isPlatformAdmin() {
      return isSignedIn() && hasUserDoc() && getUserData().role == 'platformAdmin';
    }

    // --- COLLECTION RULES ---

    // Colección de Usuarios
    match /users/{userId} {
      // Perfiles legibles por cualquier usuario autenticado
      allow read: if isSignedIn();
      // Permitir creación si está autenticado como ese mismo usuario
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Impedir escalada de privilegios al actualizar el perfil propio (role no modificable por el cliente)
      allow update: if isSignedIn() && request.auth.uid == userId && (
        !request.resource.data.keys().hasAny(['role']) || 
        request.resource.data.role == resource.data.role
      );
      // Solo el administrador de la plataforma puede borrar perfiles directamente
      allow delete: if isPlatformAdmin();
    }
    
    // Colección de Barberías (Shops)
    match /shops/{shopId} {
      // Cualquiera (clientes, invitados y dueños) puede leer los datos de la barbería para agendar citas o ver información
      allow read: if true;
      // Creación permitida para el dueño (usando UID directo o relacionando ownerId) o administrador
      allow create: if isSignedIn() && (request.auth.uid == shopId || request.resource.data.ownerId == request.auth.uid || isPlatformAdmin());
      // Edición permitida para el dueño, sin cambiar el ID de la barbería
      allow update: if isSignedIn() && (
        request.auth.uid == shopId || 
        resource.data.ownerId == request.auth.uid || 
        isPlatformAdmin()
      ) && request.resource.data.id == resource.data.id;
      // Borrado permitido solo para el dueño o administrador
      allow delete: if isSignedIn() && (request.auth.uid == shopId || resource.data.ownerId == request.auth.uid || isPlatformAdmin());
    }
    
    // Colección de Reservas (Bookings)
    match /bookings/{bookingId} {
      // Lectura pública de reservas para permitir verificar horarios y disponibilidad en tiempo real
      allow read, list: if true;
      // Creación pública permitida para soportar reservas ágiles de clientes autenticados e invitados
      allow create: if true;
      // Edición o cancelación permitida para usuarios autenticados
      allow update, delete: if isSignedIn();
    }
    
    // Colección de Sesiones de Espejo Virtual (Mirror Sessions)
    match /mirror_sessions/{sessionId} {
      // Regla de aislamiento estricto de PII: solo el dueño de la sesión puede leer o escribir sus datos
      allow read, write: if isSignedIn() && sessionId == request.auth.uid;
    }
    
    // Colección de Artículos de Blog (Blog Posts)
    match /blogPosts/{postId} {
      // Artículos legibles públicamente para soporte SEO y mercadeo
      allow read, list: if true;
      // Creación autorizada únicamente para el dueño de la barbería (comprobando shopId directo o ownerId relacional) o admin
      allow create: if isSignedIn() && (
        request.resource.data.shopId == request.auth.uid || 
        get(/databases/$(database)/documents/shops/$(request.resource.data.shopId)).data.ownerId == request.auth.uid || 
        isPlatformAdmin()
      );
      // Edición restringida al dueño de la barbería respectiva
      allow update: if isSignedIn() && (
        (resource.data.shopId == request.auth.uid && request.resource.data.shopId == resource.data.shopId) || 
        (get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid && request.resource.data.shopId == resource.data.shopId) || 
        isPlatformAdmin()
      );
      // Eliminación permitida para el dueño o admin
      allow delete: if isSignedIn() && (
        resource.data.shopId == request.auth.uid || 
        get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid || 
        isPlatformAdmin()
      );
    }
    
    // Colección de Logs de Seguridad (Security Logs)
    match /securityLogs/{logId} {
      // Solo escritura para auditoría del sistema
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
    
    // Colección de Tickets de Soporte (Support Tickets)
    match /supportTickets/{ticketId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.shopId == request.auth.uid || 
        resource.data.email == request.auth.token.email || 
        isPlatformAdmin()
      );
      allow update: if isSignedIn() && isPlatformAdmin();
      allow delete: if false;
    }
    
    // Colección de Consentimientos de Usuario (GDPR / Privacidad)
    match /userConsents/{consentId} {
      // Se permite la creación para cualquier usuario (incluidos los invitados o visitantes anónimos)
      // para que puedan registrar su aceptación de las políticas GDPR y cookies antes o después de autenticarse.
      allow create: if true;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPlatformAdmin());
      allow update, delete: if false;
    }

    // --- FREEMIUM SUBSCRIPTION SYSTEM COLLECTIONS ---

    // Colección de Suscripciones (subscriptions)
    match /subscriptions/{userId} {
      // Un usuario solo puede leer y crear/actualizar su propia suscripción, o el administrador de la plataforma
      allow read: if isSignedIn() && (userId == request.auth.uid || isPlatformAdmin());
      allow create, update: if isSignedIn() && (userId == request.auth.uid || isPlatformAdmin());
      allow delete: if isPlatformAdmin();
    }

    // Colección de Registros de Pago (payments)
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPlatformAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isPlatformAdmin();
    }

    // Colección de Registro de Uso Mensual (usage)
    match /usage/{usageDocId} {
      allow read, write: if isSignedIn();
    }

    // Colección de Planes de Suscripción (plans)
    match /plans/{planId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // Colección de Historial de Pago (paymentHistory & paymentLogs)
    match /paymentHistory/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPlatformAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isPlatformAdmin();
    }

    match /paymentLogs/{docId} {
      allow read, write: if isPlatformAdmin();
    }

    // Colección de Feature Flags (featureFlags)
    match /featureFlags/{flagId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // Colección de Configuración Global del Sistema (systemConfig)
    match /systemConfig/{configId} {
      // Configuración de precios y promociones es de lectura pública o autenticada
      allow read: if true;
      // Solo administradores pueden modificar precios y parámetros del sistema
      allow write: if isPlatformAdmin();
    }
  }
}
