rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Función de ayuda para verificar autenticación
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Colección de Usuarios
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || resource == null);
    }

    // Barberías (Shops)
    match /shops/{shopId} {
      allow read: if true; // Cualquier cliente puede ver las barberías
      allow write: if isAuthenticated(); // Solo dueños registrados pueden modificarlas
    }

    // Citas (Bookings)
    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if true; // Permite reservas tanto de clientes registrados como de invitados
    }

    // Registros de Seguridad (GDPR / Auditorías)
    match /securityLogs/{logId} {
      allow read, write: if isAuthenticated();
    }

    // Tickets de Soporte
    match /supportTickets/{ticketId} {
      allow read, write: if isAuthenticated();
    }

    // Consentimiento de Datos (GDPR)
    match /userConsents/{consentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource == null);
    }

    // Análisis de Visajismo y Estilos (Mirror Visagismo - requerido para guardar simulaciones)
    match /analyses/{analysisId} {
      allow read, write: if true; // Permite a usuarios e invitados guardar y leer sus análisis de estilo
    }
  }
}
