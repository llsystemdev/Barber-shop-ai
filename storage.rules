rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir leer y escribir imágenes de cortes de cabello y avatares de forma segura
    match /haircuts/{shopId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.contentType.matches('image/.*') 
                   && request.resource.size < 10 * 1024 * 1024;
    }
    
    match /avatars/{shopId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.contentType.matches('image/.*') 
                   && request.resource.size < 10 * 1024 * 1024;
    }
    
    // Regla de seguridad por defecto para cualquier otro archivo
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
