# Puerto en el que corre el servidor (por defecto 3000)
PORT=3000

# API Key de Google Gemini (requerida para las funciones de Inteligencia Artificial)
GEMINI_API_KEY=
API_KEY=

# Stripe API Keys (para la integración de pasarela de pagos)
